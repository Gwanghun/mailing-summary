# ============================================================
# Gmail Newsletter Summary System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Gmail
GMAIL_USER=your-email@gmail.com
GOOGLE_CREDENTIALS_PATH=data/credentials.json
GOOGLE_TOKEN_PATH=data/token.json

# Gmail SMTP (App Password - 2FA required)
# Generate at: Google Account > Security > App Passwords
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Digest recipient
DIGEST_RECIPIENT=your-email@gmail.com

# Claude API
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-6

# Processing settings
LOOKBACK_HOURS=24
MAX_EMAILS_PER_RUN=50
MIN_IMPORTANCE_SCORE=2

# Environment: local | github_actions
ENVIRONMENT=local
LOG_LEVEL=INFO
